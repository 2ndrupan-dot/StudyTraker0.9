# Firebase configuration
# These are the Firebase project credentials for StudyTrack.
# Copy this file to .env.local and fill in your values,
# OR set them as environment variables in your deployment platform (e.g. Render).
#
# NOTE: Firebase client-side API keys are safe to expose publicly —
# they are NOT secret. Security is enforced via Firebase Security Rules.
# However, using env vars keeps the config flexible across environments.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
